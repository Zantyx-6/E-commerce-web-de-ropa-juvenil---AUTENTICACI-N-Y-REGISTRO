# ==================== DATABASE ====================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:1234@localhost:5432/EcommercePruebas"

# ==================== SERVER ====================
# Port where the Express server will run
PORT=3000

# ==================== JWT CONFIGURATION ====================
# CRITICAL: This must be set in production. The server will not start without it.
# Use a strong, random string (at least 32 characters recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT token expiration time (default: 7d)
# Supported formats: '7d', '24h', '3600s', etc.
JWT_EXPIRY="7d"

# ==================== FRONTEND CONFIGURATION ====================
# CORS origin for the frontend (used in development)
# Update this if your frontend runs on a different port
CLIENT_ORIGIN="http://localhost:5173"

# ==================== SEED USERS ====================
ADMIN_SEED_PASSWORD="AdminPassword123!"
CLIENT_SEED_PASSWORD="Cliente123!"

# ==================== SECURITY ====================
# Rate limiting for authentication endpoints
# Max attempts per time window (in milliseconds)
# Current: 5 attempts per 15 minutes for auth endpoints
# Global: 100 requests per 60 seconds for all endpoints
